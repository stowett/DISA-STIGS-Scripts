.USAGE
    Put any usage instructions here.
    Example syntax:
    PS C:\> .\__remediation_template(STIG-ID-WN11-AU-000560).ps1 

#> # Ensure script runs as Administrator
$IsAdmin = ([Security.Principal.WindowsPrincipal] `
    [Security.Principal.WindowsIdentity]::GetCurrent()
).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

if (-not $IsAdmin) {
    Write-Host "Please run this script as Administrator." -ForegroundColor Red
    exit
}

# Apply STIG setting: Enable success auditing for "Other Logon/Logoff Events"
auditpol /set /subcategory:"Other Logon/Logoff Events" /success:enable

Write-Host "Audit policy applied: Other Logon/Logoff Events (Success Enabled)"

# Verify configuration
Write-Host "`nVerifying settings..."
auditpol /get /subcategory:"Other Logon/Logoff Events"

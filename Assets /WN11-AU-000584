.USAGE
    Put any usage instructions here.
    Example syntax:
    PS C:\> .\__remediation_template(STIG-ID-WN11-AU-000584).ps1 

#> # Ensure Administrator
$IsAdmin = ([Security.Principal.WindowsPrincipal] `
    [Security.Principal.WindowsIdentity]::GetCurrent()
).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

if (-not $IsAdmin) {
    Write-Host "Run PowerShell as Administrator." -ForegroundColor Red
    exit
}

# Define subcategory (WN11-AU-000584)
$SubCategory = "Handle Manipulation"

Write-Host "Applying STIG: WN11-AU-000584 -> $SubCategory (Success)" -ForegroundColor Cyan

# Apply STIG setting
auditpol /set /subcategory:"$SubCategory" /success:enable | Out-Null

# Optional (STIG environments often also enable failure logging for forensics)
auditpol /set /subcategory:"$SubCategory" /failure:enable | Out-Null

Write-Host "`nVerifying configuration..." -ForegroundColor Yellow

# Verification
auditpol /get /subcategory:"$SubCategory"

Write-Host "`nSTIG configuration applied successfully." -ForegroundColor Green

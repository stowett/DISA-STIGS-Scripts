#> # ==============================
# WN11-CC-000204
# Limit Enhanced Diagnostic Data
# ==============================

# Ensure Administrator privileges
$IsAdmin = ([Security.Principal.WindowsPrincipal] `
    [Security.Principal.WindowsIdentity]::GetCurrent()
).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

if (-not $IsAdmin) {
    Write-Host "ERROR: Run PowerShell as Administrator." -ForegroundColor Red
    exit
}

# Define registry path
$regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection"

Write-Host "`nApplying STIG WN11-CC-000204..." -ForegroundColor Cyan

# Create registry path if it does not exist
if (-not (Test-Path $regPath)) {
    New-Item -Path $regPath -Force | Out-Null
    Write-Host "Created registry path: $regPath"
}

# ==============================
# STIG CONFIGURATION
# ==============================

# Set telemetry to minimum required level
New-ItemProperty -Path $regPath `
    -Name "AllowTelemetry" `
    -Value 1 -PropertyType DWord -Force

Write-Host "`nTelemetry set to minimum required level (1)."

# Optional hardening (commonly used in enterprise STIG baselines)
New-ItemProperty -Path $regPath `
    -Name "DisableEnterpriseAuthProxy" `
    -Value 1 -PropertyType DWord -Force

New-ItemProperty -Path $regPath `
    -Name "DoNotShowFeedbackNotifications" `
    -Value 1 -PropertyType DWord -Force

# ==============================
# VERIFICATION
# ==============================

Write-Host "`nVerifying configuration..." -ForegroundColor Yellow

Get-ItemProperty -Path $regPath

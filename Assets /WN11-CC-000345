#> # ==============================
# WN11-AU-000345 - WinRM Service Hardening
# Registry: HKLM\SOFTWARE\Policies\Microsoft\Windows\WinRM\Service
# ==============================

# Ensure Administrator privileges
$IsAdmin = ([Security.Principal.WindowsPrincipal] `
    [Security.Principal.WindowsIdentity]::GetCurrent()
).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

if (-not $IsAdmin) {
    Write-Host "ERROR: Run PowerShell as Administrator." -ForegroundColor Red
    exit
}

# Define registry path
$regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\WinRM\Service"

Write-Host "`nApplying STIG WN11-AU-000345 (WinRM Service)..." -ForegroundColor Cyan

# Create registry path if missing
if (-not (Test-Path $regPath)) {
    New-Item -Path $regPath -Force | Out-Null
    Write-Host "Created registry path: $regPath"
}

# ==============================
# STIG-HARDENED SETTINGS
# ==============================

# Disable unencrypted traffic
New-ItemProperty -Path $regPath `
    -Name "AllowUnencryptedTraffic" `
    -Value 0 -PropertyType DWord -Force

# Require basic authentication OFF (more secure auth methods required)
New-ItemProperty -Path $regPath `
    -Name "AllowBasic" `
    -Value 0 -PropertyType DWord -Force

# Disallow CredSSP unless explicitly required
New-ItemProperty -Path $regPath `
    -Name "AllowCredSSPAuthentication" `
    -Value 0 -PropertyType DWord -Force

Write-Host "`nWinRM Service STIG settings applied successfully."

# ==============================
# VERIFICATION
# ==============================
Write-Host "`nVerifying configuration..." -ForegroundColor Yellow

Get-ItemProperty -Path $regPath


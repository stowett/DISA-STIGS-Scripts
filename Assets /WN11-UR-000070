#> # ==============================
# WN11-UR-000070
# Deny access to this computer from the network
# ==============================

# Ensure Administrator privileges
$IsAdmin = ([Security.Principal.WindowsPrincipal] `
    [Security.Principal.WindowsIdentity]::GetCurrent()
).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

if (-not $IsAdmin) {
    Write-Host "ERROR: Run PowerShell as Administrator." -ForegroundColor Red
    exit
}

Write-Host "`nApplying STIG WN11-UR-000070..." -ForegroundColor Cyan


# Create INF security template
# ==============================

$infPath = "$env:TEMP\wn11_ur_000070.inf"
$dbPath  = "$env:TEMP\wn11_ur_000070.sdb"

@"
[Version]
signature="`$CHICAGO`$"
Revision=1

[Privilege Rights]
SeDenyNetworkLogonRight = *S-1-5-32-546,*S-1-5-113
"@ | Out-File -Encoding ASCII $infPath


# Apply security template
# ==============================
secedit /configure /db $dbPath /cfg $infPath /areas USER_RIGHTS

# Verify setting
# ==============================
Write-Host "`nVerifying applied policy..." -ForegroundColor Yellow

secedit /export /areas USER_RIGHTS /cfg "$env:TEMP\verify_ura.inf"

Select-String -Path "$env:TEMP\verify_ura.inf" -Pattern "SeDenyNetworkLogonRight"

Write-Host "`nSTIG WN11-UR-000070 applied successfully." -ForegroundColor Green
